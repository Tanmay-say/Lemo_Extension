# === LLM API Keys ===
# Use either Gemini or Emergent LLM key (system will check both)
GEMINI_API_KEY="your_gemini_api_key_here"

# Primary reasoning model (Lemo agent final responses).
# Real id on v1beta is `gemini-3.1-pro-preview` (or use `gemini-pro-latest`).
GEMINI_MODEL="gemini-3.1-pro-preview"
# Cheap/fast model (IntentTracker agent, analysis tasks).
GEMINI_FAST_MODEL="gemini-flash-lite-latest"
# Embedding model for current-page vector retrieval.
# `text-embedding-004` is removed; `gemini-embedding-001` is the replacement.
GEMINI_EMBED_MODEL="gemini-embedding-001"

EMERGENT_LLM_KEY="your_emergent_llm_key_here"
LLM_PROVIDER="auto"
EMERGENT_BASE_URL="https://api.emergent.ai/v1"
LLM_TIMEOUT_SECONDS=30
# Streaming budget for the Lemo agent. Gemini 3.x Pro thinking-model streams
# can legitimately run 45-75s, so keep this well above LLM_TIMEOUT_SECONDS.
LLM_STREAM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# === Database ===
DATABASE_URL="postgresql://username:password@host:port/database"

# === Redis ===
REDIS_URL="redis://default:password@host:port"

# === Scraping ===
SCRAPINGBEE_API_KEY="your_scrapingbee_api_key_here"

# === JWT Authentication ===
JWT_SECRET_KEY="generate_a_secure_random_string_here"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=60
